#
# General
#
COMPOSE_PROJECT_NAME=r3ngine

#
# SSL specific configuration
#
AUTHORITY_NAME=r3Ngine
# CHANGE ME: set a strong random password (e.g. openssl rand -base64 32)
AUTHORITY_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
COMPANY=r3Ngine
DOMAIN_NAME=r3ngine.example.com
COUNTRY_CODE=US
STATE=Georgia
CITY=Atlanta

#
# Database configurations
#
POSTGRES_DB=r3ngine
POSTGRES_USER=r3ngine
# CHANGE ME: set a strong random password (e.g. openssl rand -base64 32)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_PORT=5432
POSTGRES_HOST=db
POSTGRES_SSLMODE=prefer
#
# Concurrency
#
MAX_CONCURRENCY=40
MIN_CONCURRENCY=10

#
# r3ngine web interface super user (for non-interactive install)
#
DJANGO_SUPERUSER_USERNAME=r3ngine
DJANGO_SUPERUSER_EMAIL=r3ngine@example.com
# CHANGE ME: set a strong random password (e.g. openssl rand -base64 32)
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
# CHANGE ME: set a strong random password (e.g. openssl rand -base64 32)

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=CHANGE_ME
NEO4J_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
NEO4J_USER=neo4j
NEO4J_URI=bolt://neo4j:7687

# Redis configurations
# CHANGE ME: set a strong random password (e.g. openssl rand -base64 32)
REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
#
# Security — optional overrides
#
# Restrict CORS to your actual frontend origin(s) in production
# CORS_ALLOWED_ORIGINS=https://your-rengine-domain.example.com
# Set allowed hosts (comma-separated) in production
# ALLOWED_HOSTS=your-rengine-domain.example.com
# Obscure the Django admin URL from /admin/ to something less guessable
# DJANGO_ADMIN_URL=your_secret_admin_path
# Acunetix CA bundle path (if Acunetix uses a self-signed cert you trust)
# ACUNETIX_CA_BUNDLE=/path/to/ca-bundle.pem

